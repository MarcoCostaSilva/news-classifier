# Dados (não versionar dataset bruto/processado)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Modelos treinados: model_v1.joblib é versionado propositalmente (ver README),
# pois os testes automatizados de CI dependem dele estar disponível. Outras
# versões experimentais (ex. model_v2_full.joblib) continuam ignoradas.
models/*.joblib
!models/model_v1.joblib
models/*.pkl

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Notebooks checkpoints
.ipynb_checkpoints/

# Ambiente
.env

# IDE
.vscode/
.idea/